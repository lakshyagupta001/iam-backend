        {
          "name": "Attach Policy to Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/groups/{{groupId}}/policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups", "{{groupId}}", "policies"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyId\": \"{{policyId}}\"\n}"
            }
          }
        },
        {
          "name": "Detach Policy from Group",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/groups/{{groupId}}/policies/{{policyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups", "{{groupId}}", "policies", "{{policyId}}"]
            }
          }
        }
