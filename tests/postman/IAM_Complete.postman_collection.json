              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/policies/{{policyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "policies", "{{policyId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ReportsReadOnly_Updated\"\n}"
            }
