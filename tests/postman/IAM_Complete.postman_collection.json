              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups", "{{groupId}}", "members"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            }
          }
        },
        {
          "name": "Remove User from Group",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/groups/{{groupId}}/members/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups", "{{groupId}}", "members", "{{userId}}"]
            }
