{
  "info": {
    "name": "Phase 3 Complete IAM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organization (Root)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Root User\",\n  \"email\": \"glakshya01@gmail.com\",\n  \"password\": \"Pass@123\",\n  \"organizationName\": \"My Org\"\n}"
            }
          }
        },
        {
          "name": "Login Root User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let responseData = pm.response.json();",
                  "if (responseData.success && responseData.data && responseData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"authToken\", responseData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"glakshya01@gmail.com\",\n  \"password\": \"Pass@123\"\n}"
            }
          }
        },
        {
          "name": "Login Normal User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let responseData = pm.response.json();",
                  "if (responseData.success && responseData.data && responseData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"authToken\", responseData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"yashojha@gmail.com\",\n  \"password\": \"Pass@123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Normal User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Yash Ojha\",\n  \"email\": \"yashojha@gmail.com\",\n  \"password\": \"Pass@123\"\n}"
            }
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "users"]
            }
          }
        },
        {
          "name": "Attach Policy to User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/users/{{userId}}/policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "users", "{{userId}}", "policies"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyId\": \"{{policyId}}\"\n}"
            }
          }
        },
        {
          "name": "Detach Policy from User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/users/{{userId}}/policies/{{policyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "users", "{{userId}}", "policies", "{{policyId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Groups",
