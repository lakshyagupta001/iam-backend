    },
    {
      "name": "Policies",
      "item": [
        {
          "name": "Create Policy",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "policies"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ReportsReadOnly\",\n  \"description\": \"Allows read access to reports\",\n  \"type\": \"MANAGED\",\n  \"statements\": [\n    {\n      \"effect\": \"Allow\",\n      \"actions\": [\n        \"reports:Read\",\n        \"reports:List\"\n      ],\n      \"resource\": \"*\"\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Policies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/policies?page=1&limit=10&type=MANAGED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "policies"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "MANAGED" }
              ]
            }
          }
        },
        {
          "name": "Get Policy By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
