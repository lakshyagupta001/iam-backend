        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iam/groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Developers\",\n  \"description\": \"Frontend Development Team\"\n}"
            }
          }
        },
        {
          "name": "Get All Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/iam/groups?page=1&limit=10&search=Dev",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iam", "groups"],
